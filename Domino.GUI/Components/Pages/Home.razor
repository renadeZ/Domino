@page "/"
@rendermode InteractiveServer
@using Domino.Backend
@using Domino.Backend.Models
@using Domino.Backend.Models.Enums
@using Domino.Backend.Models.EventArgs
@using System.Timers
@inject GameController Controller
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>DOMINO</PageTitle>

@if (!isGameStarted)
{
    <!-- Fixed Centered Start Screen -->
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; justify-content: center; align-items: center; z-index: 9999; background: rgba(0,0,0,0.6);">
        <div style="text-align: center; color: white; padding: 50px 80px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.8); border: 2px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.8);">
            <h1 style="font-size: 4rem; text-shadow: 2px 4px 10px rgba(0,0,0,0.8); margin-bottom: 30px; letter-spacing: 2px; white-space: nowrap;">DOMINO</h1>
            <button class="btn btn-primary btn-lg" style="padding: 15px 50px; font-size: 1.5rem; border-radius: 30px; font-weight: bold; box-shadow: 0 4px 15px rgba(0,0,0,0.5); transition: transform 0.2s;" @onclick="StartGame">Start Game</button>
        </div>
    </div>
}
else if (isGameOver)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h2 style="font-size: 2.5rem; color: #2c3e50;">Game Over!</h2>
            <h3 style="color: #e67e22;">Winner: @gameWinner</h3>
            <div style="text-align: left; margin: 20px; background: rgba(255,255,255,0.5); padding: 20px; border-radius: 10px;">
                @foreach (var score in Controller.DominoGameDto.Scores.OrderByDescending(x => x.Value))
                {
                    <p style="font-size: 1.2rem; font-weight: bold;">@score.Key.Name : @score.Value Points</p>
                }
            </div>
            <button @onclick="RestartGame">Play Again</button>
        </div>
    </div>
}
else
{
    <div class="game-container" style="max-width: 1000px; margin: 0 auto;">
        
        <!-- Header / Info -->
        <div class="header-info">
            <div>
                <h3 style="margin: 0; font-size: 1.8rem;">Round: @Controller.DominoGameDto.RoundNumber</h3>
                <h4 style="margin: 5px 0 0 0; color: #f1c40f;">Current Turn: @CurrentPlayer.Name</h4>
            </div>
            
            <!-- Timer Display -->
            <div style="text-align: center; margin: 0 20px; padding: 10px 20px; background: rgba(0,0,0,0.5); border-radius: 10px; border: 2px solid @(timeLeft <= 10 ? "#e74c3c" : "#2ecc71");">
                <span style="font-size: 1.8rem; font-weight: bold; color: @(timeLeft <= 10 ? "#e74c3c" : "#2ecc71"); text-shadow: 0 2px 5px rgba(0,0,0,0.5);">
                    ⏳ @timeLeft s
                </span>
            </div>

            <div style="text-align: right; font-size: 0.95rem;">
                @foreach (var player in Controller.DominoGameDto.PlayerHands)
                {
                    <div style="margin-bottom: 3px;">
                        <span style="color: #bdc3c7;">@player.Key.Name :</span> 
                        <span style="font-weight: bold; color: #ecf0f1;">@Controller.DominoGameDto.Scores[player.Key] Pts</span> 
                        <span style="color: #f39c12; margin-left: 5px;">(@player.Value.Count() Cards)</span>
                    </div>
                }
            </div>
        </div>

        <!-- Board -->
        <div class="domino-board">
            @if (Controller.DominoGameDto.Board.Chain.Count == 0)
            {
                <h3 style="color: rgba(255,255,255,0.3); font-style: italic;">Board is empty</h3>
            }
            else
            {
                @foreach (var tile in Controller.DominoGameDto.Board.Chain)
                {
                    <div class="domino-card @(tile.Top == tile.Bottom ? "" : "horizontal")" data-is-balak="@(tile.Top == tile.Bottom ? "true" : "false")">
                        <div class="domino-half val-@tile.Top">
                            @for (int i = 0; i < tile.Top; i++)
                            {
                                <div class="dot"></div>
                            }
                        </div>
                        <div class="domino-half val-@tile.Bottom">
                            @for (int i = 0; i < tile.Bottom; i++)
                            {
                                <div class="dot"></div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Player Hand -->
        <div style="margin-top: 15px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <h3 style="color: white; text-shadow: 1px 2px 5px rgba(0,0,0,0.8); margin: 0;">Your Hand (@CurrentPlayer.Name)</h3>
                @if (PlayableTiles.Count == 0)
                {
                    <button class="btn btn-warning" style="padding: 5px 20px; font-weight: bold; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.5);" @onclick="PassTurn">Pass Turn</button>
                }
            </div>
            
            <div class="player-hand">
                @foreach (var tile in PlayableTiles)
                {
                    <div class="domino-card" @onclick="() => SelectTile(tile)">
                        <div class="domino-half val-@tile.Top">
                            @for (int i = 0; i < tile.Top; i++)
                            {
                                <div class="dot"></div>
                            }
                        </div>
                        <div class="domino-half val-@tile.Bottom">
                            @for (int i = 0; i < tile.Bottom; i++)
                            {
                                <div class="dot"></div>
                            }
                        </div>
                    </div>
                }

                @foreach (var tile in UnplayableTiles)
                {
                    <div class="domino-card unplayable">
                        <div class="domino-half val-@tile.Top">
                            @for (int i = 0; i < tile.Top; i++)
                            {
                                <div class="dot"></div>
                            }
                        </div>
                        <div class="domino-half val-@tile.Bottom">
                            @for (int i = 0; i < tile.Bottom; i++)
                            {
                                <div class="dot"></div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sleek Modal for Side Selection -->
    @if (showSideSelectionModal && selectedTile != null)
    {
        <div class="sleek-modal-overlay">
            <div class="sleek-modal-content">
                <h4 style="margin-bottom: 25px; color: #ecf0f1; font-weight: 300;">Where to place this tile?</h4>
                <div class="domino-card horizontal" style="margin: 0 auto 30px auto; transform: scale(1.3); cursor: default; box-shadow: 0 15px 30px rgba(0,0,0,0.6);">
                    <div class="domino-half val-@selectedTile.Top">
                        @for (int i = 0; i < selectedTile.Top; i++) { <div class="dot"></div> }
                    </div>
                    <div class="domino-half val-@selectedTile.Bottom">
                        @for (int i = 0; i < selectedTile.Bottom; i++) { <div class="dot"></div> }
                    </div>
                </div>
                <div style="display: flex; justify-content: center; gap: 20px;">
                    <button class="btn-left" @onclick="() => PlayTile(PlacementSide.Left)">⬅ Left End</button>
                    <button class="btn-right" @onclick="() => PlayTile(PlacementSide.Right)">Right End ➡</button>
                </div>
                <button class="btn-cancel" @onclick="CancelSelection">Cancel</button>
            </div>
        </div>
    }

    <!-- Modal for Turn Completed -->
    @if (showTurnCompletedModal)
    {
        <div class="modal-overlay" style="z-index: 3000; background: rgba(0,0,0,0.85);">
            <div class="modal-content" style="background: @(isTimeout ? "linear-gradient(145deg, #e74c3c, #c0392b)" : "#34495e"); color: white; border: 2px solid @(isTimeout ? "#ff7979" : "#2980b9"); animation: scaleUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;">
                @if (isTimeout)
                {
                    <h2 style="font-size: 2rem; margin-bottom: 15px; color: white;">
                        <span style="font-size: 2.5rem;">⏱️</span> Time Limit Passed, You Get Penalty
                    </h2>
                }
                else
                {
                    <h2 style="font-size: 2rem; margin-bottom: 15px; color: #3498db;">
                        Your turn completed
                    </h2>
                }
                
                <p style="font-size: 1.5rem; margin-bottom: 25px;">
                    Next turn : <span style="font-weight: bold; color: #f1c40f;">@CurrentPlayer.Name</span>
                </p>
                <button class="btn btn-primary" style="padding: 10px 30px; font-size: 1.2rem; border-radius: 10px; background-color: @(isTimeout ? "white" : "#3498db"); color: @(isTimeout ? "#c0392b" : "white"); border: none; font-weight: bold;" @onclick="AcknowledgeTurnCompleted">Continue</button>
            </div>
        </div>
    }

    <!-- Modal for Round Ended -->
    @if (showRoundEndedModal)
    {
        <div class="modal-overlay">
            <div class="modal-content">
                <h2 style="color: #2c3e50;">Round Ended</h2>
                <h3 style="color: #27ae60;">Winner: @roundWinner</h3>
                <p style="font-size: 1.2rem; font-weight: bold; margin: 20px 0;">Result: @roundResultMsg</p>
                <button @onclick="ContinueNextRound">Continue Next Round</button>
            </div>
        </div>
    }
}

@code {
    private bool isGameStarted = false;
    private bool isGameOver = false;
    private bool showSideSelectionModal = false;
    private bool showRoundEndedModal = false;
    private bool showTurnCompletedModal = false;
    private bool isTimeout = false;
    
    private IDominoTile? selectedTile;
    private string roundWinner = "";
    private string roundResultMsg = "";
    private string gameWinner = "";

    // Timer logic
    private Timer? turnTimer;
    private int timeLeft = 30;

    private IPlayer CurrentPlayer => Controller.DominoGameDto?.Players[Controller.DominoGameDto.CurrentPlayerIndex]!;
    private List<IDominoTile> PlayableTiles = new();
    private List<IDominoTile> UnplayableTiles = new();

    protected override void OnInitialized()
    {
        Controller.RoundEnded += OnRoundEnded;
        Controller.TurnCompleted += OnTurnCompleted;
        Controller.GameOver += OnGameOver;

        turnTimer = new Timer(1000);
        turnTimer.Elapsed += OnTimerTick;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Removed JSRuntime.InvokeVoidAsync("layoutDominoes") to avoid messy snake wrapping.
        await Task.CompletedTask;
    }

    public void Dispose()
    {
        Controller.RoundEnded -= OnRoundEnded;
        Controller.TurnCompleted -= OnTurnCompleted;
        Controller.GameOver -= OnGameOver;

        if (turnTimer != null)
        {
            turnTimer.Stop();
            turnTimer.Elapsed -= OnTimerTick;
            turnTimer.Dispose();
        }
    }

    private void OnTimerTick(object? sender, ElapsedEventArgs e)
    {
        if (!isGameStarted || isGameOver || showRoundEndedModal || showSideSelectionModal || showTurnCompletedModal) return;

        timeLeft--;
        if (timeLeft <= 0)
        {
            turnTimer?.Stop();
            InvokeAsync(() =>
            {
                CancelSelection();
                isTimeout = true;
                Controller.ApplyTimeOut(CurrentPlayer); 
            });
        }
        else
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private void StartGame()
    {
        Controller.StartGame();
        Controller.StartRound();
        isGameStarted = true;
        UpdateHand();
        ResetTimer();
    }

    private void RestartGame()
    {
        isGameOver = false;
        Controller.StartGame();
        Controller.StartRound();
        UpdateHand();
        ResetTimer();
    }

    private void UpdateHand()
    {
        if (Controller.DominoGameDto != null && !isGameOver && !showRoundEndedModal)
        {
            PlayableTiles = Controller.GetPlayableTiles(CurrentPlayer);
            UnplayableTiles = Controller.GetUnplayableTiles(CurrentPlayer);
        }
    }

    private void SelectTile(IDominoTile tile)
    {
        var validSides = Controller.GetValidPlacements(tile);
        
        if (Controller.DominoGameDto.Board.Chain.Count == 0 && validSides.Count > 0)
        {
            PlayTile(tile, validSides[0]);
        }
        else if (validSides.Count == 1)
        {
            PlayTile(tile, validSides[0]);
        }
        else if (validSides.Count == 2)
        {
            selectedTile = tile;
            showSideSelectionModal = true;
        }
    }

    private void PlayTile(PlacementSide side)
    {
        if (selectedTile != null)
        {
            PlayTile(selectedTile, side);
            showSideSelectionModal = false;
            selectedTile = null;
        }
    }

    private void PlayTile(IDominoTile tile, PlacementSide side)
    {
        bool success = Controller.MakeMove(CurrentPlayer, tile, side);
        if (success)
        {
            UpdateHand();
        }
    }

    private void PassTurn()
    {
        Controller.Pass(CurrentPlayer);
    }

    private void CancelSelection()
    {
        showSideSelectionModal = false;
        selectedTile = null;
        StateHasChanged();
    }

    private void ContinueNextRound()
    {
        showRoundEndedModal = false;
        Controller.StartRound();
        UpdateHand();
        ResetTimer();
        StateHasChanged();
    }

    private void OnTurnCompleted(object? sender, EventArgs e)
    {
        turnTimer?.Stop();
        InvokeAsync(() =>
        {
            UpdateHand();
            showSideSelectionModal = false;
            selectedTile = null;
            showTurnCompletedModal = true;
            StateHasChanged();
        });
    }

    private void AcknowledgeTurnCompleted()
    {
        showTurnCompletedModal = false;
        isTimeout = false;
        ResetTimer();
        StateHasChanged();
    }

    private void ResetTimer()
    {
        timeLeft = 30;
        turnTimer?.Start();
    }

    private void OnRoundEnded(object? sender, GameEventArgs e)
    {
        turnTimer?.Stop();
        InvokeAsync(() =>
        {
            roundWinner = e.Player.Name;
            roundResultMsg = $"{e.Result} (+{e.ScoreChange} pts)";
            showRoundEndedModal = true;
            showSideSelectionModal = false;
            showTurnCompletedModal = false;
            isTimeout = false;
            StateHasChanged();
        });
    }

    private void OnGameOver(object? sender, GameEventArgs e)
    {
        turnTimer?.Stop();
        InvokeAsync(() =>
        {
            gameWinner = e.Player.Name;
            isGameOver = true;
            showRoundEndedModal = false;
            showSideSelectionModal = false;
            showTurnCompletedModal = false;
            isTimeout = false;
            StateHasChanged();
        });
    }
}